# Django backend host base URL
VITE_API_BASE_URL=http://127.0.0.1:8000

# Optional dashboard endpoint relative to VITE_API_BASE_URL
# Leave blank if dashboard endpoint is not implemented yet
VITE_DASHBOARD_ENDPOINT=

# true: fallback to mock data when API fails, false: strict API mode
VITE_USE_MOCK_FALLBACK=true
